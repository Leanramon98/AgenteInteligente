rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    match /users/{userId}/agents/{agentId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /agents/{agentId}/{allPaths=**} {
      allow read, write: if request.auth != null; 
    }
  }
}
