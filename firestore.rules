rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user owns the agent
    function isOwner(agentId) {
      return request.auth != null && 
        (get(/databases/$(database)/documents/agents/$(agentId)).data.userId == request.auth.uid);
    }

    match /agents/{agentId} {
      allow read, write: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    match /kb_documents/{docId} {
      allow read, write: if request.auth != null && isOwner(request.resource.data.agentId || resource.data.agentId);
      allow create: if request.auth != null && isOwner(request.resource.data.agentId);
    }

    match /kb_faqs/{faqId} {
      allow read, write: if request.auth != null && isOwner(request.resource.data.agentId || resource.data.agentId);
      allow create: if request.auth != null && isOwner(request.resource.data.agentId);
    }
    
    match /kb_chunks/{chunkId} {
      allow read: if true; // Public for searching
      allow write: if false; // Only Cloud Functions should write here
    }

    match /conversations/{convId} {
      allow read, write: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
    }

    match /messages/{msgId} {
      allow read: if true;
      allow create: if true; // Allow guests to message if needed, or restrict later
    }
  }
}
